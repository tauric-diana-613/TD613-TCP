# TD613 server-side Gemini configuration
# Copy to .env.local for local server/proxy development.
# Never commit real API keys.

GEMINI_API_KEY=
GEMINI_ROUTING_MODE=quality-first

# Optional global exact-model override. Blank values use the repository's
# pinned quality-first text order. Avoid moving *-latest aliases in production.
GEMINI_MODEL=
GEMINI_MODEL_FALLBACKS=
GEMINI_DISABLED_MODELS=

# Optional route-specific overrides. Route-specific values take precedence.
HUSH_GEMINI_MODEL=
HUSH_GEMINI_FALLBACKS=
KHONAPOLIT_GEMINI_MODEL=
KHONAPOLIT_GEMINI_FALLBACKS=

# Browser-facing Hush provider posture. The server selects the actual model.
HUSH_REMOTE_PROVIDER=gemini
HUSH_REMOTE_MODEL=auto-quality
