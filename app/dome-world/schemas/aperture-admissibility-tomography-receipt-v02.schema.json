{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.aperture.admissibility-tomography-receipt/v0.2",
  "title": "TD613 Aperture admissibility tomography receipt v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "receipt_id", "created_at", "time_posture", "aperture_version", "experiment_id", "assurance_class", "status", "source_commitment", "instrument_ensemble", "snapshot_lattice", "coverage", "reference_layers", "registry_model", "shared_layer_relaxation", "phason_susceptibility", "temporal_route_object", "signed_residual_ledger", "heldout_validation", "alternative_models", "benign_controls", "missingness", "holds", "abstention_reason", "automatic_ash_action", "prediction_authorized", "derivative_authorized", "source_status", "evidence_basis", "observations", "alternatives", "open_questions", "operator_notes", "closure", "receipt_digest"],
  "properties": {
    "schema": { "const": "td613.aperture.admissibility-tomography-receipt/v0.2" },
    "receipt_id": { "type": "string", "pattern": "^attomo_[A-Za-z0-9_-]{6,128}$" },
    "created_at": { "type": "string" },
    "time_posture": { "const": "local-clock-not-trusted-time" },
    "aperture_version": { "const": "v3.1-alpha" },
    "experiment_id": { "type": "string" },
    "assurance_class": { "enum": ["AT0_DESCRIPTIVE_CONSTELLATION", "AT1_SINGLE_COORDINATE", "AT2_FACTORIAL_REGISTRY", "AT3_MULTI_TIME_TOMOGRAPHY", "AT4_CROSS_ENVIRONMENT"] },
    "status": { "enum": ["ABSTAIN", "TOMOGRAPHY_READY_WITH_WARNINGS", "TOMOGRAPHY_READY"] },
    "source_commitment": { "type": "object" },
    "instrument_ensemble": { "type": "object" },
    "snapshot_lattice": { "type": "object" },
    "coverage": { "type": "object" },
    "reference_layers": {},
    "registry_model": {},
    "shared_layer_relaxation": {},
    "phason_susceptibility": {},
    "temporal_route_object": {},
    "signed_residual_ledger": {},
    "heldout_validation": { "type": "object" },
    "alternative_models": { "type": "array", "items": { "type": "string" } },
    "benign_controls": { "type": "array", "items": { "type": "string" } },
    "missingness": { "type": "array" },
    "holds": { "type": "array", "items": { "type": "string" } },
    "abstention_reason": { "type": ["string", "null"] },
    "automatic_ash_action": { "const": false },
    "prediction_authorized": { "const": false },
    "derivative_authorized": { "const": false },
    "source_status": { "const": "DERIVED" },
    "evidence_basis": { "$ref": "#/$defs/textList" },
    "observations": { "type": "object" },
    "alternatives": { "$ref": "#/$defs/textList" },
    "open_questions": { "$ref": "#/$defs/textList" },
    "operator_notes": { "$ref": "#/$defs/textList" },
    "closure": { "$ref": "#/$defs/closure" },
    "receipt_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "textList": { "type": "array", "items": { "type": "string" } },
    "closure": { "type": "object", "required": ["required", "status"], "properties": { "required": { "const": true }, "status": { "enum": ["OPEN", "CLOSED"] } }, "additionalProperties": false }
  }
}
