{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.aperture.composition-constitution-plan/v0.1",
  "title": "TD613 Aperture Composition Constitution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "version", "plan_id", "created_at", "layer_order",
    "station_ownership", "consumer_contracts", "read_only_projection_required",
    "provenance_visible_required", "warning_collapse_allowed", "raw_source_allowed",
    "candidate_body_allowed", "case_map_body_allowed", "route_memory_body_allowed",
    "provider_log_allowed", "reader_result_body_allowed", "ui_mount_authorized",
    "automatic_instrument_selection", "automatic_model_selection", "promotion_authorized",
    "release_authorized", "transport_authorized", "cinder_action_authorized",
    "automatic_hold", "automatic_ash_action", "universal_score", "evidence_basis",
    "missingness", "alternatives", "open_questions", "operator_notes", "closure", "plan_digest"
  ],
  "properties": {
    "schema": { "const": "td613.aperture.composition-constitution-plan/v0.1" },
    "version": { "const": "v0.1" },
    "plan_id": { "type": "string", "pattern": "^apcomp_plan_[A-Za-z0-9_-]{6,128}$" },
    "created_at": { "type": "string" },
    "layer_order": { "const": [
      "AUTHORITY_CONTEXT", "CONTROLLED_SOURCE", "INSTRUMENT_ENSEMBLE",
      "SNAPSHOT_LATTICE", "EXPERIMENT_RUN", "TOMOGRAPHY_RECEIPT",
      "CHOIR_CALIBRATION_BINDING", "HUSH_INTERVENTION_RECEIPT", "PRESENTATION_PROJECTION"
    ] },
    "station_ownership": { "type": "object" },
    "consumer_contracts": { "type": "object" },
    "read_only_projection_required": { "const": true },
    "provenance_visible_required": { "const": true },
    "warning_collapse_allowed": { "const": false },
    "raw_source_allowed": { "const": false },
    "candidate_body_allowed": { "const": false },
    "case_map_body_allowed": { "const": false },
    "route_memory_body_allowed": { "const": false },
    "provider_log_allowed": { "const": false },
    "reader_result_body_allowed": { "const": false },
    "ui_mount_authorized": { "const": false },
    "automatic_instrument_selection": { "const": false },
    "automatic_model_selection": { "const": false },
    "promotion_authorized": { "const": false },
    "release_authorized": { "const": false },
    "transport_authorized": { "const": false },
    "cinder_action_authorized": { "const": false },
    "automatic_hold": { "const": false },
    "automatic_ash_action": { "const": false },
    "universal_score": { "type": "null" },
    "evidence_basis": { "type": "array", "items": { "type": "string" } },
    "missingness": { "type": "array", "items": { "type": "string" } },
    "alternatives": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "operator_notes": { "type": "array", "items": { "type": "string" } },
    "closure": { "type": "object" },
    "plan_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
