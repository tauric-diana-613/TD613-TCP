{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.aperture.instrument-adapter-receipt/v0.1",
  "title": "TD613 Aperture Instrument Adapter Receipt v0.1",
  "type": "object",
  "required": [
    "schema", "receipt_id", "created_at", "time_posture", "adapter_id",
    "adapter_class", "source_status", "input_contract", "output_contract",
    "transformation_history", "missingness", "operational_state",
    "claim_authority", "target_operational_state", "no_authority_transfer",
    "automatic_model_selection", "automatic_run_promotion", "automatic_ash_action",
    "scope_statement", "cannot_establish", "promotion_conditions",
    "operator_closure", "adapter_digest", "seal"
  ],
  "properties": {
    "schema": { "const": "td613.aperture.instrument-adapter-receipt/v0.1" },
    "receipt_id": { "type": "string", "pattern": "^atadapter_[A-Za-z0-9_-]{6,128}$" },
    "created_at": { "type": "string" },
    "time_posture": { "const": "local-clock-not-trusted-time" },
    "adapter_id": { "type": "string" },
    "adapter_class": { "enum": ["EO-RFD", "ACEDIT", "KIRA", "DECLARED_INSTRUMENT"] },
    "source_status": { "enum": ["OBSERVED", "SUPPLIED", "DERIVED", "SIMULATED", "INFERRED", "ATTESTED", "UNRESOLVED"] },
    "input_contract": { "type": "string" },
    "output_contract": { "type": "string" },
    "transformation_history": { "type": "array", "items": { "type": "string" } },
    "missingness": { "type": "array", "items": { "type": "string" } },
    "operational_state": { "type": "string" },
    "claim_authority": { "type": "string" },
    "target_operational_state": { "type": "string" },
    "no_authority_transfer": { "const": true },
    "automatic_model_selection": { "const": false },
    "automatic_run_promotion": { "const": false },
    "automatic_ash_action": { "const": false },
    "scope_statement": { "type": "string" },
    "cannot_establish": { "type": "array", "items": { "type": "string" } },
    "promotion_conditions": { "type": "array", "items": { "type": "string" } },
    "operator_closure": { "type": "object" },
    "adapter_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "seal": { "const": "⟐" }
  },
  "not": {
    "anyOf": [
      { "required": ["artifact_digest"] },
      { "required": ["identity_proof"] },
      { "required": ["runtime_authority"] }
    ]
  },
  "additionalProperties": false
}
