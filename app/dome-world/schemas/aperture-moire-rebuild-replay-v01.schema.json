{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.aperture.moire-rebuild-replay/v0.1",
  "title": "TD613 Aperture Moire Rebuild Replay v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "replay_id",
    "created_at",
    "source_assay_id",
    "source_assay_digest",
    "status",
    "assay_content_restored",
    "reconstruction_reexecuted",
    "network_called",
    "storage_mutated",
    "automatic_ash_action",
    "prediction_authorized",
    "recommendation_not_command",
    "observations",
    "missingness",
    "alternatives",
    "open_questions",
    "closure",
    "replay_digest"
  ],
  "properties": {
    "schema": { "const": "td613.aperture.moire-rebuild-replay/v0.1" },
    "replay_id": { "type": "string", "pattern": "^moirereplay_[A-Za-z0-9_-]{6,128}$" },
    "created_at": { "type": "string" },
    "source_assay_id": { "type": ["string", "null"] },
    "source_assay_digest": {
      "oneOf": [
        { "type": "null" },
        { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      ]
    },
    "status": { "enum": ["MOIRE_REPLAY_VERIFIED", "MOIRE_REPLAY_HELD"] },
    "assay_content_restored": { "const": false },
    "reconstruction_reexecuted": { "const": false },
    "network_called": { "const": false },
    "storage_mutated": { "const": false },
    "automatic_ash_action": { "const": false },
    "prediction_authorized": { "const": false },
    "recommendation_not_command": { "const": true },
    "observations": { "type": "array" },
    "missingness": { "type": "array", "items": { "type": "string" } },
    "alternatives": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "closure": {
      "type": "object",
      "required": ["required", "status"],
      "properties": {
        "required": { "const": true },
        "status": { "type": "string" }
      }
    },
    "replay_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
