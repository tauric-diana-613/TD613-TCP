{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.aperture.presentation-projection/v0.1",
  "title": "TD613 Aperture Presentation Projection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "projection_id",
    "created_at",
    "composition_receipt_reference",
    "composition_receipt_digest",
    "status",
    "receipt_verified",
    "forbidden_paths",
    "case_reference",
    "layer_order",
    "layer_references",
    "composition_state",
    "holds",
    "tomography_posture",
    "choir_posture",
    "hush_posture",
    "render_contract",
    "raw_source_present",
    "candidate_body_present",
    "case_map_body_present",
    "route_memory_body_present",
    "provider_log_present",
    "reader_result_body_present",
    "ui_mounted",
    "ui_mount_authorized",
    "instruments_executed",
    "readers_executed",
    "provider_called",
    "network_called",
    "storage_mutated",
    "promotion_authorized",
    "release_authorized",
    "transport_authorized",
    "cinder_action_authorized",
    "automatic_hold",
    "automatic_ash_action",
    "recommendation_not_command",
    "universal_score",
    "projection_digest"
  ],
  "properties": {
    "schema": {
      "const": "td613.aperture.presentation-projection/v0.1"
    },
    "version": {
      "const": "v0.1"
    },
    "projection_id": {
      "type": "string",
      "pattern": "^apcomp_projection_[A-Za-z0-9_-]{6,128}$"
    },
    "created_at": {
      "type": "string"
    },
    "composition_receipt_reference": {
      "type": [
        "string",
        "null"
      ]
    },
    "composition_receipt_digest": {
      "type": [
        "string",
        "null"
      ]
    },
    "status": {
      "enum": [
        "PRESENTATION_READY",
        "PRESENTATION_HELD"
      ]
    },
    "receipt_verified": {
      "type": "boolean"
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "case_reference": {
      "type": [
        "string",
        "null"
      ]
    },
    "layer_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "layer_references": {
      "type": "object"
    },
    "composition_state": {
      "type": [
        "string",
        "null"
      ]
    },
    "holds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tomography_posture": {
      "type": "object"
    },
    "choir_posture": {
      "type": "object"
    },
    "hush_posture": {
      "type": "object"
    },
    "render_contract": {
      "type": "object"
    },
    "raw_source_present": {
      "const": false
    },
    "candidate_body_present": {
      "const": false
    },
    "case_map_body_present": {
      "const": false
    },
    "route_memory_body_present": {
      "const": false
    },
    "provider_log_present": {
      "const": false
    },
    "reader_result_body_present": {
      "const": false
    },
    "ui_mounted": {
      "const": false
    },
    "ui_mount_authorized": {
      "const": false
    },
    "instruments_executed": {
      "const": false
    },
    "readers_executed": {
      "const": false
    },
    "provider_called": {
      "const": false
    },
    "network_called": {
      "const": false
    },
    "storage_mutated": {
      "const": false
    },
    "promotion_authorized": {
      "const": false
    },
    "release_authorized": {
      "const": false
    },
    "transport_authorized": {
      "const": false
    },
    "cinder_action_authorized": {
      "const": false
    },
    "automatic_hold": {
      "const": false
    },
    "automatic_ash_action": {
      "const": false
    },
    "recommendation_not_command": {
      "const": true
    },
    "universal_score": {
      "type": "null"
    },
    "projection_digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
