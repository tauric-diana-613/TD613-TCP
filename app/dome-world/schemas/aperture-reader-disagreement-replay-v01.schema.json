{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.aperture.reader-disagreement-replay/v0.1",
  "title": "TD613 Reader Disagreement Replay v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "version", "replay_id", "created_at", "source_ledger_id",
    "source_ledger_digest", "registry_reference", "status",
    "ledger_digest_verified", "registry_digest_verified",
    "provenance_set_verified", "provenance_references_verified",
    "summaries_restored_from_ledger", "raw_reader_inputs_restored",
    "raw_reader_results_restored", "readers_reexecuted", "provider_called",
    "network_called", "storage_mutated", "transport_authorized",
    "release_authorized", "identity_inference_authorized",
    "authorship_attribution_authorized", "ownership_inference_authorized",
    "prediction_authorized", "automatic_hold", "recommendation_not_command",
    "observations", "missingness", "alternatives", "open_questions",
    "closure", "replay_digest"
  ],
  "properties": {
    "schema": { "const": "td613.aperture.reader-disagreement-replay/v0.1" },
    "version": { "const": "v0.1" },
    "replay_id": { "type": "string", "pattern": "^readerdisagreereplay_[A-Za-z0-9_-]{6,128}$" },
    "created_at": { "type": "string" },
    "source_ledger_id": { "type": ["string", "null"] },
    "source_ledger_digest": { "type": ["string", "null"] },
    "registry_reference": { "type": ["string", "null"] },
    "status": { "enum": ["READER_DISAGREEMENT_REPLAY_VERIFIED", "READER_DISAGREEMENT_REPLAY_HELD"] },
    "ledger_digest_verified": { "type": "boolean" },
    "registry_digest_verified": { "type": "boolean" },
    "provenance_set_verified": { "type": "boolean" },
    "provenance_references_verified": { "type": "boolean" },
    "summaries_restored_from_ledger": { "const": false },
    "raw_reader_inputs_restored": { "const": false },
    "raw_reader_results_restored": { "const": false },
    "readers_reexecuted": { "const": false },
    "provider_called": { "const": false },
    "network_called": { "const": false },
    "storage_mutated": { "const": false },
    "transport_authorized": { "const": false },
    "release_authorized": { "const": false },
    "identity_inference_authorized": { "const": false },
    "authorship_attribution_authorized": { "const": false },
    "ownership_inference_authorized": { "const": false },
    "prediction_authorized": { "const": false },
    "automatic_hold": { "const": false },
    "recommendation_not_command": { "const": true },
    "observations": { "type": "array" },
    "missingness": { "type": "array", "items": { "type": "string" } },
    "alternatives": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "status"],
      "properties": {
        "required": { "const": true },
        "status": { "type": "string" }
      }
    },
    "replay_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
