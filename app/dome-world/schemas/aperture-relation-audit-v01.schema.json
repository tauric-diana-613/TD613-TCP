{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"td613.aperture.relation-audit/v0.1",
  "title":"TD613 Aperture Relation Audit v0.1",
  "type":"object","additionalProperties":true,
  "required":["schema","audit_id","relation_id","relation_digest","created_at","time_posture","stage","outcome","accepted","rejected","holds","warnings","recommendation_not_command","network_called","storage_mutated","audit_digest","seal"],
  "properties":{
    "schema":{"const":"td613.aperture.relation-audit/v0.1"},
    "audit_id":{"type":"string","pattern":"^relaud_[0-9a-f]{20}$"},
    "relation_id":{"type":["string","null"]},"relation_digest":{"type":["string","null"]},
    "created_at":{"type":"string"},"time_posture":{"const":"local-clock-not-trusted-time"},
    "stage":{"enum":["PROPOSAL","CONFIRMED","MARROWLINE_CARRIER","REPLAY","WITHDRAWAL","SUPERSESSION"]},
    "outcome":{"enum":["RELATION_PROPOSAL_ADMISSIBLE","RELATION_CONFIRMED_WITHIN_SCOPE","RELATION_WITHDRAWAL_ADMISSIBLE","RELATION_SUPERSESSION_ADMISSIBLE","RELATION_REPLAY_ADMISSIBLE","RELATION_ADMISSIBLE_WITH_WARNINGS","HOLD_NONCE_REUSE","HOLD_REFERENCE_MISMATCH","HOLD_INSUFFICIENT_RELATA","HOLD_KEY_UNAVAILABLE","HOLD_LIFECYCLE_CONTRADICTION","HOLD_PHASON_FORK","HOLD_CARRIER_MUTATION","REJECT_ARTIFACT_DISCLOSURE","REJECT_AUTHORITY_OR_IDENTITY_CLAIM"]},
    "accepted":{"type":"array"},"rejected":{"type":"array"},"holds":{"type":"array"},"warnings":{"type":"array"},
    "open_field_promotion":{"const":false},"recommendation_not_command":{"const":true},
    "network_called":{"const":false},"storage_mutated":{"const":false},
    "audit_digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"seal":{"const":"⟐"}
  }
}
