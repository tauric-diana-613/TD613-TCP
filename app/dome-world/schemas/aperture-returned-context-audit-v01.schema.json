{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.aperture.returned-context-audit/v0.1",
  "title": "TD613 Aperture Returned Context Audit v0.1",
  "type": "object",
  "required": ["schema", "audit_id", "created_at", "diagnostic_receipt_reference", "context_receipt_reference", "context_schema", "task_intent_route", "runtime_materiality", "received", "accepted", "rejected", "contradictions", "warnings", "missingness_preserved", "abstention_preserved", "authority_transfer_detected", "artifact_relation_detected", "recommendation", "recommendation_not_command", "automatic_ash_action", "prediction_authorized", "operator_closure_required"],
  "properties": {
    "schema": {"const": "td613.aperture.returned-context-audit/v0.1"},
    "audit_id": {"type": "string", "pattern": "^apret_[0-9a-f]{20}$"},
    "created_at": {"type": "string"},
    "diagnostic_receipt_reference": {"type": "string"},
    "context_receipt_reference": {"type": ["string", "null"]},
    "context_schema": {"const": "td613.flowcore.context-receipt/v0.1"},
    "task_intent_route": {"type": "string"},
    "runtime_materiality": {"enum": ["NONE", "BACKGROUND", "MATERIAL", "DISPOSITIVE"]},
    "runtime_surfaced": {"type": "boolean"},
    "open_field_promotion": {"const": false},
    "received": {"type": "array", "items": {"type": "string"}},
    "accepted": {"type": "array", "items": {"type": "string"}},
    "rejected": {"type": "array", "items": {"type": "string"}},
    "contradictions": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "missingness_preserved": {"type": "boolean"},
    "abstention_preserved": {"type": "boolean"},
    "authority_transfer_detected": {"type": "boolean"},
    "artifact_relation_detected": {"type": "boolean"},
    "recommendation": {"enum": ["CONTEXT_RECEIPT_ADMISSIBLE_FOR_BOUNDED_REVIEW", "CONTEXT_RECEIPT_ADMISSIBLE_WITH_WARNINGS", "HOLD_FOR_REPAIR", "REJECT_AUTHORITY_BREACH"]},
    "recommendation_not_command": {"const": true},
    "automatic_ash_action": {"const": false},
    "prediction_authorized": {"const": false},
    "operator_closure_required": {"const": true}
  },
  "additionalProperties": false
}
