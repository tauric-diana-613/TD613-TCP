{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.aperture.snapshot-lattice/v0.2",
  "title": "TD613 Aperture snapshot lattice v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "lattice_id", "source_id", "source_commitment", "ensemble_id", "ensemble_digest", "entries", "snapshot_count", "usable_count", "missing_count", "null_result_count", "heldout_count", "benign_control_count", "time_count", "environment_count", "replication_present", "coverage", "interpolation_performed", "missing_states_preserved", "source_status", "evidence_basis", "observations", "missingness", "alternatives", "open_questions", "operator_notes", "closure", "lattice_digest"],
  "properties": {
    "schema": { "const": "td613.aperture.snapshot-lattice/v0.2" },
    "lattice_id": { "type": "string" },
    "source_id": { "type": "string" },
    "source_commitment": { "type": "string" },
    "ensemble_id": { "type": "string" },
    "ensemble_digest": { "type": "string" },
    "entries": { "type": "array", "minItems": 1, "items": { "type": "object" } },
    "snapshot_count": { "type": "integer", "minimum": 1 },
    "usable_count": { "type": "integer", "minimum": 0 },
    "missing_count": { "type": "integer", "minimum": 0 },
    "null_result_count": { "type": "integer", "minimum": 0 },
    "heldout_count": { "type": "integer", "minimum": 0 },
    "benign_control_count": { "type": "integer", "minimum": 0 },
    "time_count": { "type": "integer", "minimum": 1 },
    "environment_count": { "type": "integer", "minimum": 1 },
    "replication_present": { "type": "boolean" },
    "coverage": { "type": "object" },
    "interpolation_performed": { "const": false },
    "missing_states_preserved": { "const": true },
    "source_status": { "type": "string" },
    "evidence_basis": { "type": "array", "items": { "type": "string" } },
    "observations": { "type": "object" },
    "missingness": { "type": "array" },
    "alternatives": { "type": "array" },
    "open_questions": { "type": "array" },
    "operator_notes": { "type": "array" },
    "closure": { "type": "object" },
    "lattice_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  }
}
