{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.ash.custody-manifest/v0.5",
  "title": "TD613 Ash Custody Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema", "artifact_id", "source_environment", "source_locator", "artifact_metadata", "privacy_boundary", "credential_reference", "ash_posture", "replay"],
  "properties": {
    "schema": { "const": "td613.ash.custody-manifest/v0.5" },
    "artifact_id": { "type": "string", "minLength": 1 },
    "source_environment": {
      "type": "string",
      "enum": ["local_file", "repo", "cloud_drive", "local_drive", "spreadsheet", "llm_chat", "manual"]
    },
    "source_locator": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "label": { "type": ["string", "null"] },
        "path_or_ref": { "type": ["string", "null"] },
        "revision": { "type": ["string", "null"] },
        "commit_sha": { "type": ["string", "null"] },
        "blob_sha": { "type": ["string", "null"] }
      }
    },
    "artifact_metadata": {
      "type": "object",
      "additionalProperties": true,
      "required": ["content_hash", "hash_scope"],
      "properties": {
        "media_type": { "type": ["string", "null"] },
        "byte_length": { "type": ["number", "integer", "null"], "minimum": 0 },
        "last_modified": { "type": ["string", "null"] },
        "content_hash": { "type": "string", "minLength": 1 },
        "hash_scope": {
          "type": "string",
          "enum": ["local-browser", "repo-blob", "provider-revision", "reference-or-provider", "metadata-or-local-browser", "unavailable"]
        }
      }
    },
    "privacy_boundary": {
      "type": "object",
      "required": ["raw_content_exported", "raw_content_retained", "server_custody", "public_weather_only"],
      "properties": {
        "raw_content_exported": { "const": false },
        "raw_content_retained": { "const": false },
        "server_custody": { "const": false },
        "public_weather_only": { "type": "boolean" }
      }
    },
    "credential_reference": {
      "type": "object",
      "required": ["credential_type", "credential_secret_recorded", "identity_proof_claimed", "permission_proof_claimed"],
      "properties": {
        "credential_type": {
          "type": "string",
          "enum": ["none", "local-possession", "repo-access", "provider-session", "operator-attested"]
        },
        "credential_secret_recorded": { "const": false },
        "identity_proof_claimed": { "const": false },
        "permission_proof_claimed": { "const": false }
      }
    },
    "ash_posture": {
      "type": "object",
      "required": ["room_route", "claim_ceiling", "recommended_tending"],
      "properties": {
        "room_route": {
          "type": "string",
          "enum": ["private-sense-only", "safe-harbor-buffer", "atrium-public-weather"]
        },
        "claim_ceiling": { "const": "ash-readiness-preview-not-sensitive-intake" },
        "recommended_tending": { "type": "array", "items": { "type": "string" } }
      }
    },
    "replay": {
      "type": "object",
      "required": ["eligible", "mode", "raw_replay_available"],
      "properties": {
        "eligible": { "type": "boolean" },
        "mode": { "const": "custody-replay-without-content" },
        "raw_replay_available": { "const": false }
      }
    }
  },
  "not": {
    "anyOf": [
      { "required": ["text"] },
      { "required": ["rawText"] },
      { "required": ["content"] },
      { "required": ["document"] },
      { "required": ["body"] },
      { "required": ["sensitiveText"] },
      { "required": ["rawBytes"] }
    ]
  }
}
