{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.ash.custody-receipt/v0.5",
  "title": "TD613 Ash Custody Receipt",
  "description": "Metadata-only Ash custody receipt with explicit L0/L1 assurance class. A receipt does not prove permission, identity, authorship, authenticity, truth, possession, or trusted time.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema",
    "receipt_id",
    "created_at",
    "assurance_class",
    "manifest",
    "public_surface",
    "export_boundary",
    "anti_extraction_defaults",
    "decision",
    "claimCeiling"
  ],
  "properties": {
    "schema": {
      "const": "td613.ash.custody-receipt/v0.5"
    },
    "receipt_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "domeWorldVersion": {
      "type": "string"
    },
    "assurance_class": {
      "type": "string",
      "enum": [
        "L0_METADATA_ONLY",
        "L1_BROWSER_LOCAL_ARTIFACT_DIGEST"
      ]
    },
    "manifest": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema",
        "artifact_metadata"
      ],
      "properties": {
        "schema": {
          "const": "td613.ash.custody-manifest/v0.5"
        },
        "artifact_metadata": {
          "type": "object",
          "required": [
            "commitment_assurance"
          ],
          "properties": {
            "commitment_assurance": {
              "type": "string",
              "enum": [
                "L0_METADATA_ONLY",
                "L1_BROWSER_LOCAL_ARTIFACT_DIGEST"
              ]
            }
          }
        }
      }
    },
    "public_surface": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "content_exported",
        "text_preview",
        "quantized_weather_only"
      ],
      "properties": {
        "content_exported": {
          "const": false,
          "description": "Raw content is never exported through the public receipt surface."
        },
        "text_preview": {
          "const": null,
          "description": "No preview text is emitted from Ash custody receipts."
        },
        "quantized_weather_only": {
          "const": true,
          "description": "Only quantized public route weather may move outward."
        },
        "visual_signature": {
          "type": "string"
        }
      }
    },
    "export_boundary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "raw_content_allowed",
        "summary_before_custody",
        "arrival_as_consent"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "raw_content_allowed": {
          "const": false
        },
        "summary_before_custody": {
          "const": false
        },
        "arrival_as_consent": {
          "const": false
        }
      }
    },
    "anti_extraction_defaults": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "local_hold",
        "no_content_export",
        "public_weather_only",
        "receipt_not_proof",
        "beauty_not_verification"
      ],
      "properties": {
        "local_hold": {
          "const": true
        },
        "no_content_export": {
          "const": true
        },
        "public_weather_only": {
          "const": true
        },
        "receipt_not_proof": {
          "const": true
        },
        "beauty_not_verification": {
          "const": true
        }
      }
    },
    "decision": {
      "type": "string",
      "minLength": 1
    },
    "claimCeiling": {
      "const": "ash-custody-receipt-not-content-custody-or-permission-proof"
    },
    "seal": {
      "type": "string"
    }
  }
}
