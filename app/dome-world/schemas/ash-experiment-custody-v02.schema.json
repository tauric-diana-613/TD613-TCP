{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.ash.experiment-custody-manifest/v0.2",
  "title": "TD613 Ash experiment custody manifest v0.2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "manifest_id", "created_at", "time_posture", "experiment_id", "source_custody", "pre_registration_digest", "instrument_ensemble_digest", "snapshot_batch_reference", "tomography_result_reference", "raw_artifact_content_present", "raw_observation_content_present", "public_stable_artifact_handle", "server_persistence", "automatic_derivative_construction", "automatic_export", "automatic_cinder_action", "source_status", "evidence_basis", "observations", "missingness", "alternatives", "open_questions", "operator_notes", "closure", "manifest_digest"],
  "properties": {
    "schema": { "const": "td613.ash.experiment-custody-manifest/v0.2" },
    "manifest_id": { "type": "string" },
    "created_at": { "type": "string" },
    "time_posture": { "const": "local-clock-not-trusted-time" },
    "experiment_id": { "type": "string" },
    "source_custody": { "type": "object" },
    "pre_registration_digest": { "$ref": "#/$defs/digest" },
    "instrument_ensemble_digest": { "$ref": "#/$defs/digest" },
    "snapshot_batch_reference": { "type": ["string", "null"] },
    "tomography_result_reference": { "type": ["string", "null"] },
    "raw_artifact_content_present": { "const": false },
    "raw_observation_content_present": { "const": false },
    "public_stable_artifact_handle": { "const": false },
    "server_persistence": { "const": false },
    "automatic_derivative_construction": { "const": false },
    "automatic_export": { "const": false },
    "automatic_cinder_action": { "const": false },
    "source_status": { "type": "string" },
    "evidence_basis": { "$ref": "#/$defs/textList" },
    "observations": { "type": "array" },
    "missingness": { "type": "array" },
    "alternatives": { "type": "array" },
    "open_questions": { "$ref": "#/$defs/textList" },
    "operator_notes": { "$ref": "#/$defs/textList" },
    "closure": { "$ref": "#/$defs/closure" },
    "manifest_digest": { "$ref": "#/$defs/digest" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "textList": { "type": "array", "items": { "type": "string" } },
    "closure": { "type": "object", "required": ["required", "status"], "properties": { "required": { "const": true }, "status": { "enum": ["OPEN", "CLOSED"] } }, "additionalProperties": false }
  }
}
