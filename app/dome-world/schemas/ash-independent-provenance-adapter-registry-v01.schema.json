{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.ash.independent-provenance-adapter-registry/v0.1",
  "title": "TD613 Independent Provenance Adapter Registry v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "version",
    "registry_id",
    "created_at",
    "adapters",
    "evidence_class_count",
    "digest_domain_count",
    "adapter_schema_count",
    "state",
    "registry_eligible",
    "failed_checks",
    "missingness",
    "operator_notes",
    "closure",
    "raw_body_present",
    "raw_corpus_present",
    "universal_join_key",
    "provider_called",
    "reader_executed",
    "network_called",
    "storage_mutated",
    "identity_inference_authorized",
    "authorship_inference_authorized",
    "truth_inference_authorized",
    "destination_transport_authorized",
    "release_authorized",
    "suppression_authorized",
    "cinder_action_authorized",
    "automatic_hold",
    "recommendation_not_command",
    "registry_digest"
  ],
  "properties": {
    "schema": { "const": "td613.ash.independent-provenance-adapter-registry/v0.1" },
    "version": { "const": "v0.1" },
    "registry_id": { "type": "string", "pattern": "^indprovregistry_[A-Za-z0-9_-]{6,160}$" },
    "created_at": { "type": "string" },
    "adapters": { "type": "array", "minItems": 1, "maxItems": 11, "items": { "$ref": "#/$defs/adapter" } },
    "evidence_class_count": { "type": "integer", "minimum": 1, "maximum": 11 },
    "digest_domain_count": { "type": "integer", "minimum": 1, "maximum": 11 },
    "adapter_schema_count": { "type": "integer", "minimum": 1, "maximum": 11 },
    "state": { "enum": ["INDEPENDENT_PROVENANCE_REGISTRY_ELIGIBLE", "UNSUPPORTED_DOMAIN_HOLD", "COLLISION_HOLD", "TAMPER_HOLD"] },
    "registry_eligible": { "type": "boolean" },
    "failed_checks": { "type": "array", "items": { "type": "string" } },
    "missingness": { "type": "array", "items": { "type": "string" } },
    "operator_notes": { "type": "array", "items": { "type": "string" } },
    "closure": { "$ref": "#/$defs/closure" },
    "raw_body_present": { "const": false },
    "raw_corpus_present": { "const": false },
    "universal_join_key": { "type": "null" },
    "provider_called": { "const": false },
    "reader_executed": { "const": false },
    "network_called": { "const": false },
    "storage_mutated": { "const": false },
    "identity_inference_authorized": { "const": false },
    "authorship_inference_authorized": { "const": false },
    "truth_inference_authorized": { "const": false },
    "destination_transport_authorized": { "const": false },
    "release_authorized": { "const": false },
    "suppression_authorized": { "const": false },
    "cinder_action_authorized": { "const": false },
    "automatic_hold": { "const": false },
    "recommendation_not_command": { "const": true },
    "registry_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
  },
  "$defs": {
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_id", "evidence_class", "adapter_schema", "digest_domain", "reference_prefix",
        "verification_mode", "source_local_only", "raw_body_ingestion_authorized",
        "provider_execution_authorized", "reader_execution_authorized",
        "identity_inference_authorized", "authorship_inference_authorized",
        "permission_inference_authorized", "authenticity_inference_authorized",
        "truth_inference_authorized", "relation_inference_authorized",
        "custody_inference_authorized", "external_time_inference_authorized",
        "recipient_behavior_inference_authorized", "destination_transport_authorized"
      ],
      "properties": {
        "adapter_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{2,127}$" },
        "evidence_class": { "type": "string" },
        "adapter_schema": { "type": "string" },
        "digest_domain": { "type": "string" },
        "reference_prefix": { "type": "string" },
        "verification_mode": { "const": "SOURCE_LOCAL_DIGEST_MATCH" },
        "source_local_only": { "const": true },
        "raw_body_ingestion_authorized": { "const": false },
        "provider_execution_authorized": { "const": false },
        "reader_execution_authorized": { "const": false },
        "identity_inference_authorized": { "const": false },
        "authorship_inference_authorized": { "const": false },
        "permission_inference_authorized": { "const": false },
        "authenticity_inference_authorized": { "const": false },
        "truth_inference_authorized": { "const": false },
        "relation_inference_authorized": { "const": false },
        "custody_inference_authorized": { "const": false },
        "external_time_inference_authorized": { "const": false },
        "recipient_behavior_inference_authorized": { "const": false },
        "destination_transport_authorized": { "const": false }
      }
    },
    "closure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "status"],
      "properties": { "required": { "const": true }, "status": { "type": "string" } }
    }
  }
}
