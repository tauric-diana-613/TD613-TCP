{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.ash.independent-provenance-replay/v0.1",
  "title": "TD613 Independent Provenance Replay v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "version", "replay_id", "created_at", "source_verification_id",
    "source_verification_digest", "registry_reference", "adapter_id", "evidence_class", "state",
    "replay_verified", "registry_digest_verified", "source_verification_digest_verified",
    "adapter_relation_verified", "replay_jurisdiction_preserved", "failed_checks",
    "raw_body_restored", "raw_corpus_restored", "provider_reexecuted", "reader_reexecuted",
    "network_called", "storage_mutated", "identity_inferred", "authorship_inferred",
    "permission_inferred", "authenticity_inferred", "truth_inferred", "relation_inferred",
    "custody_inferred", "external_time_inferred", "delivery_inferred", "recipient_behavior_inferred",
    "universal_join_key", "destination_transport_authorized", "release_authorized",
    "suppression_authorized", "cinder_action_authorized", "automatic_hold",
    "recommendation_not_command", "closure", "replay_digest"
  ],
  "properties": {
    "schema": { "const": "td613.ash.independent-provenance-replay/v0.1" },
    "version": { "const": "v0.1" },
    "replay_id": { "type": "string", "pattern": "^indprovreplay_[A-Za-z0-9_-]{6,160}$" },
    "created_at": { "type": "string" },
    "source_verification_id": { "type": ["string", "null"] },
    "source_verification_digest": { "$ref": "#/$defs/nullableSha256" },
    "registry_reference": { "$ref": "#/$defs/nullableSha256" },
    "adapter_id": { "type": ["string", "null"] },
    "evidence_class": { "type": ["string", "null"] },
    "state": { "enum": ["INDEPENDENT_PROVENANCE_REPLAY_VERIFIED", "REPLAY_HOLD"] },
    "replay_verified": { "type": "boolean" },
    "registry_digest_verified": { "type": "boolean" },
    "source_verification_digest_verified": { "type": "boolean" },
    "adapter_relation_verified": { "type": "boolean" },
    "replay_jurisdiction_preserved": { "type": "boolean" },
    "failed_checks": { "type": "array", "items": { "type": "string" } },
    "raw_body_restored": { "const": false },
    "raw_corpus_restored": { "const": false },
    "provider_reexecuted": { "const": false },
    "reader_reexecuted": { "const": false },
    "network_called": { "const": false },
    "storage_mutated": { "const": false },
    "identity_inferred": { "const": false },
    "authorship_inferred": { "const": false },
    "permission_inferred": { "const": false },
    "authenticity_inferred": { "const": false },
    "truth_inferred": { "const": false },
    "relation_inferred": { "const": false },
    "custody_inferred": { "const": false },
    "external_time_inferred": { "const": false },
    "delivery_inferred": { "const": false },
    "recipient_behavior_inferred": { "const": false },
    "universal_join_key": { "type": "null" },
    "destination_transport_authorized": { "const": false },
    "release_authorized": { "const": false },
    "suppression_authorized": { "const": false },
    "cinder_action_authorized": { "const": false },
    "automatic_hold": { "const": false },
    "recommendation_not_command": { "const": true },
    "closure": { "$ref": "#/$defs/closure" },
    "replay_digest": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "nullableSha256": { "anyOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }] },
    "closure": {
      "type": "object", "additionalProperties": false, "required": ["required", "status"],
      "properties": { "required": { "const": true }, "status": { "type": "string" } }
    }
  }
}
