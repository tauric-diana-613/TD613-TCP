{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.flowcore.context-series/v0.1",
  "title": "TD613 Flow-Core Context Series v0.1",
  "type": "object",
  "required": [
    "schema", "series_id", "experiment_id", "created_at", "time_posture",
    "status", "entries", "snapshot_count", "abstention_count",
    "missing_snapshot_count", "artifact_reference", "artifact_digest_present",
    "observation_content_present", "artifact_blind", "recommendation_not_command",
    "automatic_ash_action", "prediction_authorized", "server_persistence",
    "scope_statement", "cannot_establish", "operator_closure", "series_digest", "seal"
  ],
  "properties": {
    "schema": { "const": "td613.flowcore.context-series/v0.1" },
    "series_id": { "type": "string", "pattern": "^flowseries_[A-Za-z0-9_-]{6,128}$" },
    "experiment_id": { "type": "string", "pattern": "^atx_[A-Za-z0-9_-]{6,128}$" },
    "created_at": { "type": "string" },
    "time_posture": { "const": "local-clock-not-trusted-time" },
    "status": { "enum": ["OPEN", "PARTIAL", "ABSTAIN"] },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "snapshot_id", "context_receipt_reference", "diagnostic_receipt_reference",
          "source_status", "status", "context_posture", "missingness", "artifact_reference"
        ],
        "properties": {
          "snapshot_id": { "type": "string", "pattern": "^atsnap_[A-Za-z0-9_-]{6,128}$" },
          "context_receipt_reference": { "type": "string", "pattern": "^flowctx_[A-Za-z0-9_-]{6,128}$" },
          "diagnostic_receipt_reference": { "type": ["string", "null"] },
          "source_status": { "enum": ["OBSERVED", "SUPPLIED", "DERIVED", "SIMULATED", "INFERRED", "ATTESTED", "UNRESOLVED"] },
          "status": { "enum": ["OPEN", "ABSTAIN"] },
          "context_posture": { "enum": ["CONTEXT_READY", "ABSTAIN_INSUFFICIENT_CONTEXT"] },
          "missingness": { "type": "array", "items": { "type": "string" } },
          "artifact_reference": { "const": null }
        },
        "additionalProperties": false
      }
    },
    "snapshot_count": { "type": "integer", "minimum": 1 },
    "abstention_count": { "type": "integer", "minimum": 0 },
    "missing_snapshot_count": { "type": "integer", "minimum": 0 },
    "artifact_reference": { "const": null },
    "artifact_digest_present": { "const": false },
    "observation_content_present": { "const": false },
    "artifact_blind": { "const": true },
    "recommendation_not_command": { "const": true },
    "automatic_ash_action": { "const": false },
    "prediction_authorized": { "const": false },
    "server_persistence": { "const": false },
    "scope_statement": { "type": "string" },
    "cannot_establish": { "type": "array", "items": { "type": "string" } },
    "operator_closure": { "type": "object" },
    "series_digest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "seal": { "const": "⟐" }
  },
  "additionalProperties": false
}
