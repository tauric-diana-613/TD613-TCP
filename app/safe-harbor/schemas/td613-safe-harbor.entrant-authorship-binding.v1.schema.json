{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.safe-harbor.entrant-authorship-binding/v1",
  "title": "TD613 Safe Harbor Entrant Authorship Binding v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "namespace_anchor", "entrant_credential", "custody_assertion", "countersignature", "claim_ceiling"],
  "properties": {
    "schema_version": { "const": "td613.safe-harbor.entrant-authorship-binding/v1" },
    "namespace_anchor": {
      "type": "object",
      "required": ["principal", "claimed_pua", "utf16_surrogate_pair", "binding_fragment", "sac"],
      "properties": {
        "principal": { "const": "tauric.diana.613" },
        "claimed_pua": { "const": "U+10D613" },
        "utf16_surrogate_pair": { "const": "\\uDBF5\\uDE13" },
        "binding_fragment": { "const": "#9B07D8B" },
        "sac": { "const": "SAC[X6ZNK5NO51]" }
      }
    },
    "entrant_credential": {
      "type": "object",
      "required": ["shi_number", "packet_hash_sha256", "stylometric_fingerprint", "stability_digest", "blind_challenge_precommitment_digest", "blind_challenge_result_digest", "restoration_receipt_digest"],
      "properties": {
        "shi_number": { "type": "string", "pattern": "^TD613-SH-9B07D8B-[0-9A-F]{8}$" },
        "packet_hash_sha256": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
        "stylometric_fingerprint": { "type": ["string", "null"] },
        "stability_digest": { "type": ["string", "null"] },
        "blind_challenge_precommitment_digest": { "type": ["string", "null"] },
        "blind_challenge_result_digest": { "type": ["string", "null"] },
        "restoration_receipt_digest": { "type": ["string", "null"] }
      }
    },
    "custody_assertion": {
      "type": "object",
      "required": ["claimant_role", "claim", "state"],
      "properties": {
        "claimant_role": { "const": "entrant" },
        "claim": { "type": "string", "minLength": 1 },
        "state": { "enum": ["pending-countersignature", "countersigned"] }
      }
    },
    "countersignature": {
      "type": "object",
      "required": ["status", "signed_at_utc", "signature_type", "signature_digest", "signed_scope"],
      "properties": {
        "status": { "enum": ["unsigned", "countersigned"] },
        "signed_at_utc": { "type": ["string", "null"] },
        "signature_type": { "type": ["string", "null"] },
        "signature_digest": { "type": ["string", "null"] },
        "signed_scope": {
          "const": [
            "shi_number",
            "packet_hash_sha256",
            "stylometric_fingerprint",
            "stability_digest",
            "blind_challenge_precommitment_digest",
            "blind_challenge_result_digest",
            "restoration_receipt_digest",
            "authorship_and_custody_assertion"
          ]
        }
      }
    },
    "claim_ceiling": { "type": "object" }
  }
}
