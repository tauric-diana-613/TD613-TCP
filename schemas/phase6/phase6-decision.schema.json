{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "td613.hush.phase6.decision/v1",
  "title": "Phase 6 Unified Decision",
  "type": "object",
  "required": [
    "schema",
    "packet_status",
    "release_allowed",
    "safe_harbor_custody_handoff_allowed",
    "safe_harbor_handoff_allowed",
    "mask_gallery_update_allowed",
    "repair_required",
    "quarantine_required",
    "operator_review_required",
    "reasons"
  ],
  "properties": {
    "schema": { "const": "td613.hush.phase6.decision/v1" },
    "packet_status": { "enum": ["clean", "warned", "blocked", "repair_required", "unresolved_witness", "quarantine"] },
    "release_allowed": { "const": false },
    "safe_harbor_custody_handoff_allowed": {
      "type": "boolean",
      "description": "Custody-facts-only handoff posture; not release approval or authority transfer."
    },
    "safe_harbor_handoff_allowed": {
      "type": "boolean",
      "description": "Backward-compatible alias for safe_harbor_custody_handoff_allowed."
    },
    "mask_gallery_update_allowed": { "type": "boolean" },
    "repair_required": { "type": "boolean" },
    "quarantine_required": { "type": "boolean" },
    "operator_review_required": { "type": "boolean" },
    "reasons": { "type": "array" }
  },
  "additionalProperties": true
}
